# Absolute path to the Logseq-compatible graph on the Docker host.
NOTD_GRAPH_PATH=/srv/notd/graph

# UID/GID that own the graph directory on the host (`id -u` and `id -g`).
NOTD_UID=1000
NOTD_GID=1000

# Host-loopback port used only for local diagnostics. Pangolin uses the Docker network.
NOTD_PORT=4176

# Existing Docker network shared with the Pangolin Newt container.
PANGOLIN_NETWORK=pangolin
